<UserControl x:Class="LiteImageViewer.Views.EditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280"
             Background="{DynamicResource PanelBgBrush}">

    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="12,8">
                <TextBlock Text="✏️ 编辑模式" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelHeaderTextBrush}"
                           VerticalAlignment="Center" />
            </Border>

            <!-- 旋转翻转 -->
            <StackPanel Grid.Row="1" Margin="12,12,12,8">
                <TextBlock Text="旋转与翻转" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelLabelTextBrush}" Margin="0,0,0,8" />
                <WrapPanel>
                    <Button Content="↺ 左旋转"
                            Command="{Binding RotateLeftCommand}"
                            Padding="10,5" Margin="0,0,6,6"
                            Style="{StaticResource PanelButtonStyle}" />
                    <Button Content="↻ 右旋转"
                            Command="{Binding RotateRightCommand}"
                            Padding="10,5" Margin="0,0,6,6"
                            Style="{StaticResource PanelButtonStyle}" />
                    <Button Content="⇔ 水平翻转"
                            Command="{Binding FlipHorizontalCommand}"
                            Padding="10,5" Margin="0,0,6,6"
                            Style="{StaticResource PanelButtonStyle}" />
                    <Button Content="⇕ 垂直翻转"
                            Command="{Binding FlipVerticalCommand}"
                            Padding="10,5" Margin="0,0,6,6"
                            Style="{StaticResource PanelButtonStyle}" />
                </WrapPanel>
            </StackPanel>

            <Border Grid.Row="2" Height="1" Background="{DynamicResource SeparatorBrush}" Margin="12,4" />

            <!-- 调整尺寸 -->
            <StackPanel Grid.Row="3" Margin="12,8,12,8">
                <TextBlock Text="调整尺寸" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelLabelTextBrush}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="宽:" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource PanelLabelTextBrush}"
                               Margin="0,0,4,0" />
                    <TextBox Grid.Column="1" Text="{Binding ResizeWidth}"
                             Padding="4,2" Margin="0,0,8,0" FontSize="12" />
                    <TextBlock Grid.Column="2" Text="高:" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource PanelLabelTextBrush}"
                               Margin="0,0,4,0" />
                    <TextBox Grid.Column="3" Text="{Binding ResizeHeight}"
                             Padding="4,2" FontSize="12" />
                </Grid>
                <Button Content="应用尺寸调整"
                        Command="{Binding ApplyResizeCommand}"
                        Padding="10,5" Margin="0,8,0,0"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#2196F3" Foreground="White" />
            </StackPanel>

            <!-- 压缩 -->
            <StackPanel Grid.Row="4" Margin="12,8,12,8">
                <TextBlock Text="压缩" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelLabelTextBrush}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="质量:" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource PanelLabelTextBrush}"
                               Margin="0,0,8,0" />
                    <Slider Grid.Column="1" Minimum="1" Maximum="100"
                            Value="{Binding CompressionQuality, Mode=TwoWay}"
                            TickFrequency="10" IsSnapToTickEnabled="False"
                            VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                               Text="{Binding CompressionQuality}" FontSize="12"
                               Foreground="{DynamicResource PanelLabelTextBrush}"
                               MinWidth="30" TextAlignment="Right" />
                </Grid>
                <Button Content="📦 压缩图片"
                        Command="{Binding CompressCommand}"
                        Padding="10,5" Margin="0,8,0,0"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#FF9800" Foreground="White" />
            </StackPanel>

            <Border Grid.Row="5" Height="1" Background="{DynamicResource SeparatorBrush}" Margin="12,4" />

            <!-- 马赛克 -->
            <StackPanel Grid.Row="6" Margin="12,8,12,8">
                <TextBlock Text="马赛克" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelLabelTextBrush}" Margin="0,0,0,8" />
                <TextBox Text="{Binding AddTextContent}"
                         Padding="4,4" FontSize="12"
                         AcceptsReturn="False"
                         TextWrapping="NoWrap"
                         ToolTip="格式: X,Y,宽,高 (如: 100,100,200,200)" />
                <TextBlock Text="输入 X,Y,宽,高 格式"
                           FontSize="10" Foreground="{DynamicResource PanelHintTextBrush}"
                           Margin="0,4,0,8" />
                <Button Content="应用马赛克"
                        Command="{Binding ApplyMosaicCommand}"
                        Padding="10,5"
                        Style="{StaticResource PanelButtonStyle}" />
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="12,8,12,12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom">
                <Button Content="💾 保存"
                        Command="{Binding SaveEditCommand}"
                        Padding="14,6" Margin="0,0,10,0"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#4CAF50" Foreground="White" />
                <Button Content="❌ 取消编辑"
                        Command="{Binding CancelEditCommand}"
                        Padding="14,6"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#9E9E9E" Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
