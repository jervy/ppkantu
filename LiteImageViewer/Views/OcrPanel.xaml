<UserControl x:Class="LiteImageViewer.Views.OcrPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="320"
             Width="320"
             Background="{DynamicResource PanelBgBrush}">

    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="12,8">
                <Grid>
                    <TextBlock Text="OCR 文字识别" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PanelHeaderTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding OcrServiceName}"
                               FontSize="11" Foreground="{DynamicResource PanelMutedTextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="12,8">
                <Button Content="▶ 开始识别"
                        Command="{Binding RunOcrCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#4CAF50" Foreground="White" />

                <Button Content="⏹ 取消"
                        Command="{Binding CancelOcrCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#F44336" Foreground="White" />
            </StackPanel>

            <!-- 进度条 -->
            <ProgressBar Grid.Row="2"
                         Value="{Binding OcrProgress}"
                         Minimum="0" Maximum="100"
                         Height="4" Margin="12,0,12,8"
                         Background="{DynamicResource SeparatorBrush}"
                         Foreground="#4CAF50" />

            <!-- 结果文本框 -->
            <Border Grid.Row="3" Margin="12,0,12,8"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                    Background="{DynamicResource ContextMenuBgBrush}" CornerRadius="4">
                <TextBox x:Name="OcrResultTextBox"
                         Text="{Binding OcrResultText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"
                         Padding="8"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource PanelLabelTextBrush}"
                         FontFamily="Microsoft YaHei UI, Consolas" />
            </Border>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="12,0,12,12">
                <Button Content="📋 复制结果"
                        Command="{Binding CopyOcrResultCommand}"
                        Padding="10,5" Margin="0,0,8,0"
                        Style="{StaticResource PanelButtonStyle}" />

                <Button Content="💾 导出 TXT"
                        Command="{Binding ExportOcrResultCommand}"
                        Padding="10,5" Margin="0,0,8,0"
                        Style="{StaticResource PanelButtonStyle}" />

                <Button Content="🗑 清空"
                        Command="{Binding ClearOcrResultCommand}"
                        Padding="10,5"
                        Style="{StaticResource PanelButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
