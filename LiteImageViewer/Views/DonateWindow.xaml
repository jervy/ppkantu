<Window x:Class="LiteImageViewer.Views.DonateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打赏作者"
        Width="340" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}"
        Foreground="{DynamicResource StatusTextPrimaryBrush}"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid>
        <StackPanel Margin="20,20">
            <TextBlock Text="随意打赏作者，"
                       FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource StatusTextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock Text="不打赏也可以使用，无任何限制。"
                       FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource StatusTextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,2,0,16" />

            <Border Background="White"
                    CornerRadius="8"
                    Padding="12"
                    HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource StatusBarBorderBrush}"
                    BorderThickness="1">
                <Image Source="/Assets/DonateQR.png"
                       Width="200" Height="200"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <TextBlock Margin="0,12,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource StatusTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
                <Run Text="支持：" />
                <Run Text="微信" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextPrimaryBrush}" />
                <Run Text="、" />
                <Run Text="支付宝" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextPrimaryBrush}" />
                <Run Text="、" />
                <Run Text="云闪付" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextPrimaryBrush}" />
                <Run Text="、" />
                <Run Text="招行APP" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextPrimaryBrush}" />
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
