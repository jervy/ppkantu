<UserControl x:Class="LiteImageViewer.Views.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="26" d:DesignWidth="800"
             Background="{DynamicResource StatusBarBgBrush}">

    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="0,1,0,0">
        <DockPanel Margin="8,0">
            <!-- 状态消息（靠右） -->
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="{DynamicResource StatusTextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0" />

            <!-- 打赏按钮（靠左） -->
            <Border x:Name="DonateBorder"
                    Background="Transparent"
                    CornerRadius="3"
                    Margin="0,0,12,0"
                    Cursor="Hand"
                    ToolTip="打赏作者"
                    MouseLeftButtonDown="DonateButton_Click"
                    MouseEnter="DonateBorder_MouseEnter"
                    MouseLeave="DonateBorder_MouseLeave"
                    Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="☕" FontSize="13" VerticalAlignment="Center" Margin="0,0,3,0">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD4874B" Offset="0" />
                                <GradientStop Color="#FF8B5E3C" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock x:Name="DonateText"
                               Text="作者失业中，去打赏"
                               FontSize="11"
                               Foreground="{DynamicResource StatusTextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding IndexDisplay}"
                           FontSize="12" Foreground="{DynamicResource StatusTextPrimaryBrush}"
                           Margin="0,0,16,0" />
                <TextBlock Text="{Binding ImageDimensions}"
                           FontSize="12" Foreground="{DynamicResource StatusTextPrimaryBrush}"
                           Margin="0,0,16,0" />
                <TextBlock Text="{Binding ZoomDisplay}"
                           FontSize="12" Foreground="{DynamicResource StatusTextPrimaryBrush}"
                           Margin="0,0,16,0" />
                <TextBlock Text="{Binding FileSizeDisplay}"
                           FontSize="12" Foreground="{DynamicResource StatusTextPrimaryBrush}" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
