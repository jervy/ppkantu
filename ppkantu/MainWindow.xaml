<Window x:Class="Ppkantu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:chrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Ppkantu.Views"
        mc:Ignorable="d"
        WindowStyle="None"
        Background="{DynamicResource WindowBgBrush}"
        Height="710" Width="1100"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/AppIcon-256.png"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      GlassFrameThickness="-1"
                      ResizeBorderThickness="8"
                      CornerRadius="8" />
    </WindowChrome.WindowChrome>

    <!-- Styles.xaml 已在 App.xaml 全局加载，此处无需重复引入 -->

    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="34" />
            <RowDefinition x:Name="ToolbarRow" Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="StatusBarRow" Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏 -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：小图标 + 应用名 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock Text="📷" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="鹏鹏看图" FontSize="12" Foreground="{DynamicResource TitleTextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- 中间：文件路径/标题 -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="12" Foreground="{DynamicResource TitlePathTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- 右侧：窗口按钮 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,4,0">
                <Button x:Name="BtnMinimize" Content="─"
                        Width="36" Height="24"
                        Click="BtnMinimize_Click"
                        chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{StaticResource WindowButtonStyle}" />
                <Button x:Name="BtnMaximize"
                        Width="36" Height="24"
                        Click="BtnMaximize_Click"
                        chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{StaticResource WindowButtonStyle}">
                    <TextBlock Text="□"
                               FontSize="15"
                               FontWeight="SemiBold"
                               LineHeight="15"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
                <!-- 全屏按钮 -->
                <Button x:Name="BtnFullScreen"
                        Width="36" Height="24"
                        Click="BtnFullScreen_Click"
                        ToolTip="全屏模式 (F11)"
                        chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{StaticResource WindowButtonStyle}">
                    <TextBlock Text="⛶"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
                <Button x:Name="BtnClose" Content="✕"
                        Width="36" Height="24"
                        Click="BtnClose_Click"
                        chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{StaticResource CloseButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- 工具栏 -->
        <views:ToolbarControl Grid.Row="1" DataContext="{Binding}">
            <views:ToolbarControl.Style>
                <Style TargetType="views:ToolbarControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:ToolbarControl.Style>
        </views:ToolbarControl>

        <!-- 主内容区域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <views:ImageViewerControl Grid.Column="0"
                                      x:Name="ImageViewer"
                                      DataContext="{Binding}" />

            <ContentControl Grid.Column="1">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Content" Value="{x:Null}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOcrPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="Content" Value="{Binding}" />
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <views:OcrPanel DataContext="{Binding}" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="Content" Value="{Binding}" />
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <views:EditorPanel DataContext="{Binding}" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>

        <!-- 状态栏 -->
        <views:StatusBarControl Grid.Row="3" DataContext="{Binding}">
            <views:StatusBarControl.Style>
                <Style TargetType="views:StatusBarControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:StatusBarControl.Style>
        </views:StatusBarControl>
    </Grid>
</Window>
