<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 浅色主题颜色 -->
    <Color x:Key="WindowBgColor">#F0F0F0</Color>
    <Color x:Key="TitleBarBgColor">#E8E8E8</Color>
    <Color x:Key="TitleTextColor">#333333</Color>
    <Color x:Key="TitlePathTextColor">#666666</Color>

    <Color x:Key="ToolbarBgColor">#F7F7F7</Color>
    <Color x:Key="ToolbarBorderColor">#E0E0E0</Color>
    <Color x:Key="ButtonHoverBgColor">#E0E0E0</Color>
    <Color x:Key="ButtonPressedBgColor">#D0D0D0</Color>

    <Color x:Key="StatusBarBgColor">#F0F0F0</Color>
    <Color x:Key="StatusBarBorderColor">#D0D0D0</Color>
    <Color x:Key="StatusTextPrimaryColor">#666666</Color>
    <Color x:Key="StatusTextSecondaryColor">#888888</Color>

    <Color x:Key="PanelBgColor">#FAFAFA</Color>
    <Color x:Key="PanelBorderColor">#E0E0E0</Color>
    <Color x:Key="PanelHeaderBgColor">#E8E8E8</Color>
    <Color x:Key="PanelHeaderTextColor">#333333</Color>
    <Color x:Key="PanelMutedTextColor">#999999</Color>
    <Color x:Key="PanelLabelTextColor">#444444</Color>
    <Color x:Key="PanelHintTextColor">#999999</Color>

    <Color x:Key="SeparatorColor">#C0C0C0</Color>
    <Color x:Key="PanelButtonBgColor">#E8E8E8</Color>
    <Color x:Key="PanelButtonBorderColor">#CCCCCC</Color>

    <Color x:Key="ContextMenuBgColor">#FFFFFF</Color>
    <Color x:Key="ContextMenuBorderColor">#E0E0E0</Color>
    <Color x:Key="ContextMenuItemHoverColor">#E8F0FE</Color>

    <Color x:Key="WindowButtonFgColor">#666666</Color>
    <Color x:Key="WindowButtonHoverBgColor">#D0D0D0</Color>
    <Color x:Key="WindowButtonHoverFgColor">#333333</Color>
    <Color x:Key="CloseButtonHoverBgColor">#E81123</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="{StaticResource TitleBarBgColor}" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="{StaticResource TitleTextColor}" />
    <SolidColorBrush x:Key="TitlePathTextBrush" Color="{StaticResource TitlePathTextColor}" />

    <SolidColorBrush x:Key="ToolbarBgBrush" Color="{StaticResource ToolbarBgColor}" />
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="{StaticResource ToolbarBorderColor}" />
    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="{StaticResource ButtonHoverBgColor}" />
    <SolidColorBrush x:Key="ButtonPressedBgBrush" Color="{StaticResource ButtonPressedBgColor}" />

    <SolidColorBrush x:Key="StatusBarBgBrush" Color="{StaticResource StatusBarBgColor}" />
    <SolidColorBrush x:Key="StatusBarBorderBrush" Color="{StaticResource StatusBarBorderColor}" />
    <SolidColorBrush x:Key="StatusTextPrimaryBrush" Color="{StaticResource StatusTextPrimaryColor}" />
    <SolidColorBrush x:Key="StatusTextSecondaryBrush" Color="{StaticResource StatusTextSecondaryColor}" />

    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="PanelHeaderBgBrush" Color="{StaticResource PanelHeaderBgColor}" />
    <SolidColorBrush x:Key="PanelHeaderTextBrush" Color="{StaticResource PanelHeaderTextColor}" />
    <SolidColorBrush x:Key="PanelMutedTextBrush" Color="{StaticResource PanelMutedTextColor}" />
    <SolidColorBrush x:Key="PanelLabelTextBrush" Color="{StaticResource PanelLabelTextColor}" />
    <SolidColorBrush x:Key="PanelHintTextBrush" Color="{StaticResource PanelHintTextColor}" />

    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />
    <SolidColorBrush x:Key="PanelButtonBgBrush" Color="{StaticResource PanelButtonBgColor}" />
    <SolidColorBrush x:Key="PanelButtonBorderBrush" Color="{StaticResource PanelButtonBorderColor}" />

    <SolidColorBrush x:Key="ContextMenuBgBrush" Color="{StaticResource ContextMenuBgColor}" />
    <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="{StaticResource ContextMenuBorderColor}" />
    <SolidColorBrush x:Key="ContextMenuItemHoverBrush" Color="{StaticResource ContextMenuItemHoverColor}" />

    <SolidColorBrush x:Key="WindowButtonFgBrush" Color="{StaticResource WindowButtonFgColor}" />
    <SolidColorBrush x:Key="WindowButtonHoverBgBrush" Color="{StaticResource WindowButtonHoverBgColor}" />
    <SolidColorBrush x:Key="WindowButtonHoverFgBrush" Color="{StaticResource WindowButtonHoverFgColor}" />
    <SolidColorBrush x:Key="CloseButtonHoverBgBrush" Color="{StaticResource CloseButtonHoverBgColor}" />

</ResourceDictionary>
