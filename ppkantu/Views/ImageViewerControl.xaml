<UserControl x:Class="Ppkantu.Views.ImageViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"
             xmlns:chrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Background="{DynamicResource ToolbarBgBrush}"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragOver="OnDragOver"
             Drop="OnDrop"
             MouseDoubleClick="OnPlaceholderDoubleClick">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <UserControl.ContextMenu>
        <ContextMenu Style="{StaticResource ContextMenuStyle}">
            <MenuItem Header="固定到桌面" Click="ContextMenu_PinToDesktop_Click" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="退出全屏" Click="ContextMenu_ExitFullScreen_Click" Style="{StaticResource ContextMenuItemStyle}" Visibility="{Binding IsFullScreen, Converter={StaticResource BoolToVis}}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="打开文件" Command="{Binding OpenFileCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="上一张" Command="{Binding PreviousImageCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="下一张" Command="{Binding NextImageCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="适应窗口" Command="{Binding FitToWindowCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="原始大小 (100%)" Command="{Binding OriginalSizeCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="左旋转 90°" Command="{Binding RotateLeftCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="右旋转 90°" Command="{Binding RotateRightCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="另存为..." Command="{Binding SaveAsCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="复制图片" Command="{Binding CopyImageCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource ContextMenuItemStyle}" />
            <MenuItem Style="{StaticResource ContextMenuDividerStyle}" />
            <MenuItem Header="删除图片" Command="{Binding DeleteImageCommand}" Style="{StaticResource ContextMenuItemStyle}" Foreground="#CC0000" />
                    </ContextMenu>
                </UserControl.ContextMenu>

    <!-- 父 Grid：不裁剪，允许导航按钮负 Margin 延伸到窗口边缘 -->
    <Grid x:Name="RootGrid" Background="Transparent"
          MouseLeave="OnRootGridMouseLeave">

        <!-- 内部 Grid：裁剪图片缩放/平移溢出 -->
        <Grid x:Name="ViewerGrid" ClipToBounds="True"
              Background="Transparent"
              MouseWheel="OnMouseWheel">

        <!-- 图片 -->
        <Image x:Name="MainImage"
               Source="{Binding CurrentImage}"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">
            <Image.Style>
                <Style TargetType="Image">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGif}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScaleTransform" />
                    <TranslateTransform x:Name="ImageTranslateTransform" />
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- GIF 动画图片 -->
        <Image x:Name="GifImage"
               gif:ImageBehavior.AnimatedSource="{Binding CurrentGifSource}"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">
            <Image.Style>
                <Style TargetType="Image">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGif}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>

        <!-- 裁切覆盖层 -->
        <Canvas x:Name="CropOverlay" Visibility="Collapsed" Background="Transparent"
                Panel.ZIndex="20"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                MouseLeftButtonDown="OnMouseLeftButtonDown"
                MouseMove="OnMouseMove"
                MouseLeftButtonUp="OnMouseLeftButtonUp">
            <!-- 四周遮罩 -->
            <Path x:Name="CropMaskTop" Fill="#88000000" />
            <Path x:Name="CropMaskBottom" Fill="#88000000" />
            <Path x:Name="CropMaskLeft" Fill="#88000000" />
            <Path x:Name="CropMaskRight" Fill="#88000000" />
            <!-- 裁切区域边框 -->
            <Border x:Name="CropBorder" BorderBrush="White" BorderThickness="2"
                    Background="Transparent" Panel.ZIndex="1" Visibility="Collapsed" />
            <Rectangle x:Name="CropSelectionRect" Stroke="White" StrokeThickness="2"
                       Fill="Transparent" Panel.ZIndex="3" Visibility="Collapsed"
                       IsHitTestVisible="False" />
            <!-- 角标 -->
            <Canvas x:Name="CropCornerCanvas" Panel.ZIndex="2">
                <Path x:Name="CornerTL" Stroke="White" StrokeThickness="2" Data="M0,15 L0,0 L15,0" Visibility="Collapsed" />
                <Path x:Name="CornerTR" Stroke="White" StrokeThickness="2" Data="M-15,0 L0,0 L0,15" Visibility="Collapsed" />
                <Path x:Name="CornerBL" Stroke="White" StrokeThickness="2" Data="M0,-15 L0,0 L15,0" Visibility="Collapsed" />
                <Path x:Name="CornerBR" Stroke="White" StrokeThickness="2" Data="M-15,0 L0,0 L0,-15" Visibility="Collapsed" />
            </Canvas>
        </Canvas>

        <!-- 标注覆盖层 -->
        <Canvas x:Name="AnnotationOverlay" Visibility="Collapsed"
                Panel.ZIndex="20"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Canvas Background="Transparent" IsHitTestVisible="True" />
        </Canvas>

        <!-- 涂抹覆盖层 -->
        <Canvas x:Name="DoodleOverlay" Visibility="Collapsed" Background="Transparent"
                Panel.ZIndex="20"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                MouseLeftButtonDown="OnDoodleOverlayMouseDown"
                MouseMove="OnDoodleOverlayMouseMove"
                MouseLeftButtonUp="OnDoodleOverlayMouseUp" />

        <!-- 涂抹粗细选择器：涂抹模式下显示 -->
        <Border x:Name="DoodleThicknessPanel" Visibility="Collapsed"
                Panel.ZIndex="70"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="#CC2D2D2D" CornerRadius="6" Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="DoodleThinBtn" Content="细 (15)" Width="60" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnDoodleThicknessClick" Tag="15" />
                <Button x:Name="DoodleMediumBtn" Content="中 (30)" Width="60" Height="28" FontSize="11"
                        Background="#555" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnDoodleThicknessClick" Tag="30" Margin="2,0,0,0" />
                <Button x:Name="DoodleThickBtn" Content="粗 (50)" Width="60" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnDoodleThicknessClick" Tag="50" Margin="2,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 浮动操作按钮：裁切时显示"确认/取消"，标注选中时只显示"删除" -->
        <Canvas x:Name="FloatingButtonsCanvas" Visibility="Collapsed"
                Panel.ZIndex="60"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                IsHitTestVisible="True">
            <StackPanel x:Name="FloatingButtons" Orientation="Horizontal"
                        Canvas.Left="0" Canvas.Top="0">
                <Button x:Name="FloatingConfirmButton" Content="✓" Width="32" Height="28" FontSize="14" FontWeight="Bold"
                        ToolTip="确认裁切"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,2,0"
                        Click="OnFloatingConfirmClick" />
                <Button x:Name="FloatingCancelButton" Content="✕" Width="32" Height="28" FontSize="14" FontWeight="Bold"
                        ToolTip="取消裁切"
                        Background="#E53935" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,2,0"
                        Click="OnFloatingCancelClick" />
                <Button x:Name="FloatingPinButton" Content="📌" Width="32" Height="28" FontSize="13"
                        ToolTip="固定到桌面"
                        Style="{x:Null}"
                        Background="#1976D2" Foreground="White" BorderThickness="0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Click="OnFloatingPinClick" />
                <Button x:Name="FloatingDeleteButton" Content="🗑" Width="32" Height="28" FontSize="14"
                        ToolTip="删除选中的标注"
                        Background="#E53935" Foreground="White" BorderThickness="0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Click="OnFloatingDeleteClick" />
            </StackPanel>
        </Canvas>

        <!-- 浮动标注工具栏：标注模式下显示工具选择 -->
        <Border x:Name="AnnotationToolbarCanvas" Visibility="Collapsed"
                Panel.ZIndex="70"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="#CC2D2D2D" CornerRadius="6" Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ToolRectangleBtn" Content="▭ 矩形" Width="64" Height="28" FontSize="11"
                        Background="#555" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Rectangle" />
                <Button x:Name="ToolEllipseBtn" Content="○ 圆形" Width="64" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Ellipse" Margin="2,0,0,0" />
                <Button x:Name="ToolLineBtn" Content="╱ 线条" Width="64" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Line" Margin="2,0,0,0" />
                <Button x:Name="ToolArrowBtn" Content="→ 箭头" Width="64" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Arrow" Margin="2,0,0,0" />
                <Button x:Name="ToolBrushBtn" Content="✎ 自由" Width="64" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Brush" Margin="2,0,0,0" />
                <Button x:Name="ToolTextBtn" Content="T 文字" Width="64" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnAnnotationToolClick" Tag="Text" Margin="2,0,0,0" />
                <!-- 颜色选择 -->
                <Border Width="1" Height="20" Background="#555" Margin="6,0" VerticalAlignment="Center" />
                <Ellipse x:Name="ColorRedBtn" Width="16" Height="16" Fill="#E53935" Stroke="White" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FFE53935" Margin="2,0" />
                <Ellipse x:Name="ColorBlueBtn" Width="16" Height="16" Fill="#2196F3" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FF2196F3" Margin="2,0" />
                <Ellipse x:Name="ColorGreenBtn" Width="16" Height="16" Fill="#4CAF50" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FF4CAF50" Margin="2,0" />
                <Ellipse x:Name="ColorYellowBtn" Width="16" Height="16" Fill="#FFC107" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FFFFC107" Margin="2,0" />
                <Ellipse x:Name="ColorOrangeBtn" Width="16" Height="16" Fill="#FF9800" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FFFF9800" Margin="2,0" />
                <Ellipse x:Name="ColorPurpleBtn" Width="16" Height="16" Fill="#9C27B0" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FF9C27B0" Margin="2,0" />
                <Ellipse x:Name="ColorWhiteBtn" Width="16" Height="16" Fill="White" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FFFFFFFF" Margin="2,0" />
                <Ellipse x:Name="ColorBlackBtn" Width="16" Height="16" Fill="Black" Stroke="Transparent" StrokeThickness="1.5"
                         Cursor="Hand" MouseLeftButtonDown="OnColorClick" Tag="#FF000000" Margin="2,0" />
            </StackPanel>
        </Border>

        <!-- 浮动裁切比例工具栏：裁切模式下显示比例选择 -->
        <Border x:Name="CropToolbarCanvas" Visibility="Collapsed"
                Panel.ZIndex="70"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="#CC2D2D2D" CornerRadius="6" Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ToolCropFreeBtn" Content="自由" Width="48" Height="28" FontSize="11"
                        Background="#555" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="0" />
                <Button x:Name="ToolCrop1x1Btn" Content="1:1" Width="40" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="1" Margin="2,0,0,0" />
                <Button x:Name="ToolCrop4x3Btn" Content="4:3" Width="44" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="1.333" Margin="2,0,0,0" />
                <Button x:Name="ToolCrop3x2Btn" Content="3:2" Width="44" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="1.5" Margin="2,0,0,0" />
                <Button x:Name="ToolCrop16x9Btn" Content="16:9" Width="48" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="1.778" Margin="2,0,0,0" />
                <Button x:Name="ToolCrop9x16Btn" Content="9:16" Width="48" Height="28" FontSize="11"
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand"
                        Click="OnCropRatioClick" Tag="0.5625" Margin="2,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 引导文案 -->
        <StackPanel x:Name="PlaceholderPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MouseLeftButtonDown="OnPlaceholderDoubleClick">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="📷" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3" />
            <TextBlock Text="拖拽图片到这里或双击打开" FontSize="20" Foreground="{DynamicResource PanelMutedTextBrush}" HorizontalAlignment="Center" FontWeight="Light" />
            <TextBlock Text="支持 JPG / PNG / BMP / GIF / WebP / TIFF" FontSize="12" Foreground="{DynamicResource PanelHintTextBrush}" HorizontalAlignment="Center" Margin="0,16,0,0" />
        </StackPanel>

        </Grid>

        <!-- 左侧导航按钮：单击翻页，拖动时触发窗口缩放 -->
        <Border x:Name="LeftNavBtn" Width="80" CornerRadius="0"
                Panel.ZIndex="30"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Margin="0"
                Background="#33000000" Opacity="0"
                MouseEnter="OnLeftNavMouseEnter" MouseLeave="OnLeftNavMouseLeave"
                PreviewMouseLeftButtonDown="OnPrevImageClick"
                MouseLeftButtonDown="OnPrevImageClick"
                MouseMove="OnNavResizeMouseMove"
                MouseLeftButtonUp="OnNavResizeMouseUp"
                Cursor="Hand">
            <TextBlock Text="◀" FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- 右侧导航按钮：单击翻页，拖动时触发窗口缩放 -->
        <Border x:Name="RightNavBtn" Width="80" CornerRadius="0"
                Panel.ZIndex="30"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Margin="0"
                Background="#33000000" Opacity="0"
                MouseEnter="OnRightNavMouseEnter" MouseLeave="OnRightNavMouseLeave"
                PreviewMouseLeftButtonDown="OnNextImageClick"
                MouseLeftButtonDown="OnNextImageClick"
                MouseMove="OnNavResizeMouseMove"
                MouseLeftButtonUp="OnNavResizeMouseUp"
                Cursor="Hand">
            <TextBlock Text="▶" FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

    </Grid>
</UserControl>
